{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["content"],
  "properties": {
    "content": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "nome", "endereco", "capacidades", "statusPontoGeral"],
        "properties": {
          "id": { "type": "integer" },
          "nome": { "type": "string" },
          "endereco": {
            "type": "object",
            "properties": {
              "cep": { "type": "string" },
              "logradouro": { "type": "string" },
              "bairro": { "type": "string" },
              "localidade": { "type": "string" },
              "uf": { "type": "string" },
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          },
          "capacidades": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tipoMaterial": { "type": "string" },
                "quantidadeAtual": { "type": "integer" },
                "statusCapacidade": { "type": "string" },
                "capacidade": { "type": "integer" }
              }
            }
          },
          "statusPontoGeral": { "type": "string" }
        }
      }
    }
  }
}