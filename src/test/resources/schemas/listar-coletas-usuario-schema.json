{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ColetaPageResponse",
  "type": "object",
  "properties": {
    "content": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "pontoColetaId": { "type": "integer" },
          "pontoColetaNome": { "type": "string" },
          "usuarioId": { "type": "integer" },
          "tipoMaterial": { "type": "string" },
          "quantidade": { "type": "number" },
          "dataColeta": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "pontoColetaId", "usuarioId", "tipoMaterial", "quantidade", "dataColeta"]
      }
    },
    "pageable": {
      "type": "object",
      "properties": {
        "pageNumber": { "type": "integer" },
        "pageSize": { "type": "integer" },
        "sort": { "$ref": "#/definitions/sort" },
        "offset": { "type": "integer" },
        "paged": { "type": "boolean" },
        "unpaged": { "type": "boolean" }
      }
    },
    "last": { "type": "boolean" },
    "totalElements": { "type": "integer" },
    "totalPages": { "type": "integer" },
    "size": { "type": "integer" },
    "number": { "type": "integer" },
    "sort": { "$ref": "#/definitions/sort" },
    "first": { "type": "boolean" },
    "numberOfElements": { "type": "integer" },
    "empty": { "type": "boolean" }
  },
  "definitions": {
    "sort": {
      "type": "object",
      "properties": {
        "empty": { "type": "boolean" },
        "sorted": { "type": "boolean" },
        "unsorted": { "type": "boolean" }
      }
    }
  }
}